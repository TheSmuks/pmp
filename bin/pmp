#!/bin/sh
# pmp — Pike Module Package Manager
# Thin shim: delegates all logic to bin/pmp.pike
#
# Required: Pike 8.0+, gunzip (for .tar.gz extraction), git (self-hosted only)

# Find the directory containing this script
_self="$(cd "$(dirname "$0")" && pwd)"

# Find Pike binary
_pi_bin="${PIKE_BIN:-$(command -v pike8.0 2>/dev/null || command -v pike 2>/dev/null || echo /usr/local/pike/8.0.1116/bin/pike)}"

# Delegate to the Pike implementation
exec "$_pi_bin" "$_self/pmp.pike" "$@"
