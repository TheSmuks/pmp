#!/bin/sh
# pmp — Pike Module Package Manager
#
# Usage:
#   pmp init                                    Create pike.json in current directory
#   pmp install                                 Install all deps (from lockfile or pike.json)
#   pmp install <url>                           Add dependency and install
#   pmp install <url>#tag                       Install specific version
#   pmp install -g <url>                        Install system-wide (no store)
#   pmp update                                  Update all deps to latest tags
#   pmp update <module>                         Update one dep
#   pmp lock                                    Resolve and write pike.lock without installing
#   pmp store                                   Show store entries and disk usage
#   pmp store prune                             Remove unused store entries
#   pmp list                                    Show installed dependencies
#   pmp env                                     Create isolated Pike environment (.pike-env/)
#   pmp clean                                   Remove ./modules/ (symlinks only, keeps store)
#   pmp run <script>                            Run a Pike script with module paths
#   pmp version                                 Show version

set -e

# ── Configuration ──────────────────────────────────────────────────

PMP_VERSION="0.2.0"
PIKE_BIN="${PIKE_BIN:-$(command -v pike8.0 2>/dev/null || command -v pike 2>/dev/null || echo /usr/local/pike/8.0.1116/bin/pike)}"
GLOBAL_DIR="$HOME/.pike/modules"
LOCAL_DIR="./modules"
STORE_DIR="$HOME/.pike/store"
PIKE_JSON="./pike.json"
LOCKFILE="./pike.lock"

# ── Helpers ────────────────────────────────────────────────────────

die() { echo "pmp: $*" >&2; exit 1; }

info() { printf 'pmp: %s\n' "$*"; }

warn() { printf 'pmp: warning: %s\n' "$*" >&2; }

need_cmd() { command -v "$1" >/dev/null 2>&1 || die "requires $1"; }

# Read a field from pike.json using sed (no jq dependency).
json_field() {
  _field="$1"
  _file="${2:-$PIKE_JSON}"
  [ -f "$_file" ] || return 1
  sed -n 's/.*"'"$_field"'"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$_file" | head -1
}

# Walk up from directory to find pike.json
_find_project_root() {
  _dir="${1:-$PWD}"
  while [ "$_dir" != "/" ]; do
    if [ -f "$_dir/pike.json" ]; then
      printf '%s' "$_dir"
      return 0
    fi
    _parent="$(dirname "$_dir")"
    if [ "$_parent" = "$_dir" ]; then break; fi
    _dir="$_parent"
  done
  return 1
}

# Compute SHA-256 of a file. Returns "unknown" if no tool available.
compute_sha256() {
  _file="$1"
  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$_file" | cut -d' ' -f1
  elif command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$_file" | cut -d' ' -f1
  else
    printf 'unknown'
  fi
}

# ── Source type detection ─────────────────────────────────────────
#
# Source types are detected from URL format:
#   github.com/owner/repo       -> type=github
#   gitlab.com/owner/repo       -> type=gitlab
#   git.example.com/owner/repo  -> type=selfhosted (unknown host with dots)
#   ./relative/path             -> type=local
#   /absolute/path              -> type=local
#   barename                    -> type=registry (not supported)

detect_source_type() {
  _src="$1"
  case "$_src" in
    ./*|/*)
      printf 'local'
      ;;
    *)
      case "$_src" in
        */*.*|*.*/*)
          _clean="${_src%%#*}"
          _domain="${_clean%%/*}"
          case "$_domain" in
            github.com)  printf 'github' ;;
            gitlab.com)  printf 'gitlab' ;;
            *)           printf 'selfhosted' ;;
          esac
          ;;
        */*)
          die "unsupported source format: $_src (use full URL like github.com/owner/repo)"
          ;;
        *)
          die "registry not supported yet — use full URL (e.g. github.com/owner/repo)"
          ;;
      esac
      ;;
  esac
}

# Extract the module name from the last path segment of a source URL.
source_to_name() {
  _src="$1"
  _clean="${_src%%#*}"
  _name="${_clean##*/}"
  printf '%s' "$_name"
}

# Extract version from #suffix. Empty if none.
source_to_version() {
  _src="$1"
  case "$_src" in
    *\#*) printf '%s' "${_src#*#}" ;;
    *)    printf '' ;;
  esac
}

# Strip #version from source
source_strip_version() {
  _src="$1"
  printf '%s' "${_src%%#*}"
}

# Extract domain from a host URL
source_to_domain() {
  _clean="${1%%#*}"
  printf '%s' "${_clean%%/*}"
}

# Extract owner/repo path from host URL (after domain)
source_to_repo_path() {
  _clean="${1%%#*}"
  _domain="${_clean%%/*}"
  _rest="${_clean#$_domain/}"
  printf '%s' "$_rest"
}

# ── Store helpers ─────────────────────────────────────────────────

# Generate a store entry name from source, tag, and commit SHA.
# Format: {domain}-{owner}-{repo}-{tag}-{sha_prefix8}
store_entry_name() {
  _src="$1"
  _tag="$2"
  _sha="$3"

  _clean="${_src%%#*}"
  # Convert path separators to dashes, remove leading/trailing dashes
  _slug="$(printf '%s' "$_clean" | sed 's|/|-|g; s|^-\+||; s|-\+$||')"

  _sha8="$(printf '%s' "$_sha" | cut -c1-8)"
  printf '%s-%s-%s' "$_slug" "$_tag" "$_sha8"
}

# ── Version resolution (returns tag<TAB>commit_sha) ───────────────

# Get latest tag from GitHub. Output: tag<TAB>commit_sha
latest_tag_github() {
  _repo_path="$1"
  _url="https://api.github.com/repos/$_repo_path/tags"
  _tmpfile="$(mktemp)"
  curl -sL "$_url" > "$_tmpfile" || { rm -f "$_tmpfile"; die "failed to query GitHub tags"; }

  _tag="$(sed -n 's/.*"name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$_tmpfile" | head -1)"
  if [ -n "$_tag" ]; then
    # Extract commit SHA for this tag
    # The tags API returns objects with .commit.sha
    _sha="$(sed -n '/"name"[[:space:]]*:[[:space:]]*"'"$_tag"'"/,/}/ s/.*"sha"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$_tmpfile" | head -1)"
    if [ -z "$_sha" ]; then
      # Fallback: fetch commit SHA from the ref endpoint
      _sha="$(curl -sL "https://api.github.com/repos/$_repo_path/commits/$_tag" | sed -n 's/.*"sha"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)"
    fi
    printf '%s\t%s' "$_tag" "${_sha:-unknown}"
  fi
  rm -f "$_tmpfile"
}

# Get latest tag from GitLab. Output: tag<TAB>commit_sha
latest_tag_gitlab() {
  _repo_path="$1"
  _encoded="$(printf '%s' "$_repo_path" | sed 's|/|%2F|g')"
  _url="https://gitlab.com/api/v4/projects/$_encoded/repository/tags"
  _tmpfile="$(mktemp)"
  curl -sL "$_url" > "$_tmpfile" || { rm -f "$_tmpfile"; die "failed to query GitLab tags"; }

  _tag="$(sed -n 's/.*"name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$_tmpfile" | head -1)"
  if [ -n "$_tag" ]; then
    # GitLab tags API returns .commit.id
    _sha="$(sed -n '/"name"[[:space:]]*:[[:space:]]*"'"$_tag"'"/,/"commit"/ s/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$_tmpfile" | head -1)"
    printf '%s\t%s' "$_tag" "${_sha:-unknown}"
  fi
  rm -f "$_tmpfile"
}

# Get latest tag from self-hosted git via ls-remote. Output: tag<TAB>commit_sha
latest_tag_selfhosted() {
  _domain="$1"
  _repo_path="$2"
  _url="https://$_domain/$_repo_path"
  _line="$(git ls-remote --tags "$_url" 2>/dev/null | grep -v '\^{}' | sort -t'/' -k3 -Vr | head -1)"
  if [ -n "$_line" ]; then
    _sha="$(printf '%s' "$_line" | cut -f1)"
    _tag="$(printf '%s' "$_line" | sed 's|.*refs/tags/||')"
    printf '%s\t%s' "$_tag" "$_sha"
  fi
}

# Resolve latest tag. Output: tag<TAB>commit_sha
latest_tag() {
  _type="$1"
  _domain="$2"
  _repo_path="$3"
  case "$_type" in
    github)     latest_tag_github "$_repo_path" ;;
    gitlab)     latest_tag_gitlab "$_repo_path" ;;
    selfhosted) latest_tag_selfhosted "$_domain" "$_repo_path" ;;
    *)          die "cannot resolve tags for source type: $_type" ;;
  esac
}

# Resolve a specific tag to its commit SHA.
resolve_commit_sha() {
  _type="$1"
  _domain="$2"
  _repo_path="$3"
  _tag="$4"

  case "$_type" in
    github)
      curl -sL "https://api.github.com/repos/$_repo_path/commits/$_tag" |
        sed -n 's/.*"sha"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1
      ;;
    gitlab)
      _encoded="$(printf '%s' "$_repo_path" | sed 's|/|%2F|g')"
      curl -sL "https://gitlab.com/api/v4/projects/$_encoded/repository/commits/$_tag" |
        sed -n 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1
      ;;
    selfhosted)
      git ls-remote "https://$_domain/$_repo_path" "refs/tags/$_tag" 2>/dev/null |
        cut -f1 | head -1
      ;;
    *)
      printf 'unknown'
      ;;
  esac
}

# ── Download to store ─────────────────────────────────────────────

# Download from GitHub to store. Sets _RES_TAG, _RES_SHA, _RES_HASH.
store_install_github() {
  _repo_path="$1"
  _ver="$2"

  _tmpdir="$(mktemp -d)"
  _url="https://github.com/$_repo_path/archive/refs/tags/${_ver}.tar.gz"

  info "downloading $_url"
  curl -sL "$_url" -o "$_tmpdir/archive.tar.gz" || { rm -rf "$_tmpdir"; die "failed to download $_url"; }

  _hash="$(compute_sha256 "$_tmpdir/archive.tar.gz")"

  mkdir -p "$_tmpdir/extract"
  tar -xzf "$_tmpdir/archive.tar.gz" -C "$_tmpdir/extract" || { rm -rf "$_tmpdir"; die "failed to extract archive"; }

  _extracted="$(ls "$_tmpdir/extract" | head -1)"
  [ -n "$_extracted" ] || { rm -rf "$_tmpdir"; die "empty archive"; }

  # Resolve commit SHA
  _sha="$(resolve_commit_sha github "" "$_repo_path" "$_ver")"
  _sha="${_sha:-unknown}"

  _entry_name="$(store_entry_name "github.com/$_repo_path" "$_ver" "$_sha")"
  _entry_dir="$STORE_DIR/$_entry_name"

  if [ -d "$_entry_dir" ]; then
    info "reusing existing store entry $_entry_name"
    rm -rf "$_tmpdir"
    _RES_TAG="$_ver"
    _RES_SHA="$_sha"
    _RES_HASH="$_hash"
    _RES_ENTRY="$_entry_name"
    return 0
  fi

  rm -rf "$_entry_dir"
  mkdir -p "$STORE_DIR"
  mv "$_tmpdir/extract/$_extracted" "$_entry_dir"

  # Write .pmp-meta
  cat > "$_entry_dir/.pmp-meta" << META
source	github.com/$_repo_path
tag	$_ver
commit_sha	$_sha
content_sha256	$_hash
installed_at	$(date +%s)
META

  rm -rf "$_tmpdir"
  _RES_TAG="$_ver"
  _RES_SHA="$_sha"
  _RES_HASH="$_hash"
  _RES_ENTRY="$_entry_name"
  info "stored $_entry_name"
}

# Download from GitLab to store.
store_install_gitlab() {
  _repo_path="$1"
  _ver="$2"

  _repo_name="${_repo_path##*/}"
  _tmpdir="$(mktemp -d)"
  _url="https://gitlab.com/$_repo_path/-/archive/${_ver}/${_repo_name}-${_ver}.tar.gz"

  info "downloading $_url"
  curl -sL "$_url" -o "$_tmpdir/archive.tar.gz" || { rm -rf "$_tmpdir"; die "failed to download $_url"; }

  _hash="$(compute_sha256 "$_tmpdir/archive.tar.gz")"

  mkdir -p "$_tmpdir/extract"
  tar -xzf "$_tmpdir/archive.tar.gz" -C "$_tmpdir/extract" || { rm -rf "$_tmpdir"; die "failed to extract archive"; }

  _extracted="$(ls "$_tmpdir/extract" | head -1)"
  [ -n "$_extracted" ] || { rm -rf "$_tmpdir"; die "empty archive"; }

  _sha="$(resolve_commit_sha gitlab "" "$_repo_path" "$_ver")"
  _sha="${_sha:-unknown}"

  _entry_name="$(store_entry_name "gitlab.com/$_repo_path" "$_ver" "$_sha")"
  _entry_dir="$STORE_DIR/$_entry_name"

  if [ -d "$_entry_dir" ]; then
    info "reusing existing store entry $_entry_name"
    rm -rf "$_tmpdir"
    _RES_TAG="$_ver"
    _RES_SHA="$_sha"
    _RES_HASH="$_hash"
    _RES_ENTRY="$_entry_name"
    return 0
  fi

  rm -rf "$_entry_dir"
  mkdir -p "$STORE_DIR"
  mv "$_tmpdir/extract/$_extracted" "$_entry_dir"

  cat > "$_entry_dir/.pmp-meta" << META
source	gitlab.com/$_repo_path
tag	$_ver
commit_sha	$_sha
content_sha256	$_hash
installed_at	$(date +%s)
META

  rm -rf "$_tmpdir"
  _RES_TAG="$_ver"
  _RES_SHA="$_sha"
  _RES_HASH="$_hash"
  _RES_ENTRY="$_entry_name"
  info "stored $_entry_name"
}

# Clone from self-hosted git to store.
store_install_selfhosted() {
  _domain="$1"
  _repo_path="$2"
  _ver="$3"

  _url="https://$_domain/$_repo_path"
  _tmpdir="$(mktemp -d)"

  info "cloning $_url at $_ver"
  git clone --branch "$_ver" --depth 1 "$_url" "$_tmpdir/repo" || { rm -rf "$_tmpdir"; die "failed to clone $_url"; }

  _sha="$(resolve_commit_sha selfhosted "$_domain" "$_repo_path" "$_ver")"
  _sha="${_sha:-unknown}"

  # Compute content hash by hashing a sorted tar of the cloned dir
  _hash="$(cd "$_tmpdir/repo" && find . -type f | sort | xargs sha256sum 2>/dev/null | sha256sum | cut -d' ' -f1)"
  _hash="${_hash:-unknown}"

  _entry_name="$(store_entry_name "$_domain/$_repo_path" "$_ver" "$_sha")"
  _entry_dir="$STORE_DIR/$_entry_name"

  if [ -d "$_entry_dir" ]; then
    info "reusing existing store entry $_entry_name"
    rm -rf "$_tmpdir"
    _RES_TAG="$_ver"
    _RES_SHA="$_sha"
    _RES_HASH="$_hash"
    _RES_ENTRY="$_entry_name"
    return 0
  fi

  rm -rf "$_entry_dir"
  mkdir -p "$STORE_DIR"
  mv "$_tmpdir/repo" "$_entry_dir"

  cat > "$_entry_dir/.pmp-meta" << META
source	$_domain/$_repo_path
tag	$_ver
commit_sha	$_sha
content_sha256	$_hash
installed_at	$(date +%s)
META

  rm -rf "$_tmpdir"
  _RES_TAG="$_ver"
  _RES_SHA="$_sha"
  _RES_HASH="$_hash"
  _RES_ENTRY="$_entry_name"
  info "stored $_entry_name"
}

# ── Lockfile ──────────────────────────────────────────────────────

# Write pike.lock from accumulated install results.
# _LOCK_ENTRIES accumulates lines: name<TAB>source<TAB>tag<TAB>sha<TAB>hash
_LOCK_ENTRIES=""

lockfile_add_entry() {
  _le_name="$1"
  _le_source="$2"
  _le_tag="$3"
  _le_sha="$4"
  _le_hash="$5"
  _LOCK_ENTRIES="${_LOCK_ENTRIES}${_le_name}	${_le_source}	${_le_tag}	${_le_sha}	${_le_hash}
"
}

write_lockfile() {
  if [ -z "$_LOCK_ENTRIES" ]; then
    return 0
  fi
  cat > "$LOCKFILE" << LOCKHEAD
# pmp lockfile v1 — DO NOT EDIT
# name	source	tag	commit_sha	content_sha256
LOCKHEAD
  printf '%s' "$_LOCK_ENTRIES" >> "$LOCKFILE"
  info "wrote $LOCKFILE"
}

# Read lockfile entries. Output: name<TAB>source<TAB>tag<TAB>sha<TAB>hash per line.
read_lockfile() {
  _lf="${1:-$LOCKFILE}"
  [ -f "$_lf" ] || return 1
  sed '/^#/d' "$_lf" | while IFS='	' read -r _n _s _t _sh _h; do
    [ -n "$_n" ] && printf '%s\t%s\t%s\t%s\t%s\n' "$_n" "$_s" "$_t" "$_sh" "$_h"
  done
}

# Check if a dependency name exists in the lockfile.
lockfile_has_dep() {
  _name="$1"
  _lf="${2:-$LOCKFILE}"
  [ -f "$_lf" ] || return 1
  sed '/^#/d' "$_lf" | cut -f1 | grep -qx "$_name"
}

# ── Manifest helpers ──────────────────────────────────────────────

# Add a dependency to pike.json
add_to_manifest() {
  _name="$1"
  _source="$2"
  [ -f "$PIKE_JSON" ] || return 0

  if grep -q "\"$_name\"" "$PIKE_JSON" 2>/dev/null; then
    return 0
  fi

  if grep -q '"dependencies"[[:space:]]*:[[:space:]]*{[[:space:]]*}' "$PIKE_JSON"; then
    sed -i 's|"dependencies"[[:space:]]*:[[:space:]]*{[[:space:]]*}|"dependencies": {\n    "'"$_name"'": "'"$_source"'"\n  }|' "$PIKE_JSON"
  else
    sed -i '/"dependencies"/,/^  }/ {
      /^  }/i\    "'"$_name"'": "'"$_source"'"
    }' "$PIKE_JSON"
  fi
}

# Parse dependencies from pike.json.
# Outputs lines of: module_name<TAB>source_specifier
parse_deps() {
  _file="${1:-$PIKE_JSON}"
  [ -f "$_file" ] || return 0

  _in_deps=0
  while IFS= read -r _line; do
    case "$_line" in
      *dependencies* ) _in_deps=1; continue ;;
    esac
    if [ "$_in_deps" = 1 ]; then
      case "$_line" in
        *'}'* ) _in_deps=0; continue ;;
      esac
      _name="$(printf '%s' "$_line" | sed -n 's/.*"\([^"]*\)"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')"
      _val="$(printf '%s' "$_line" | sed -n 's/.*"\([^"]*\)"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\2/p')"
      if [ -n "$_name" ] && [ -n "$_val" ]; then
        printf '%s\t%s\n' "$_name" "$_val"
      fi
    fi
  done < "$_file"
}

# ── Transitive dependency resolution ──────────────────────────────

# After installing a module, check for its own pike.json dependencies.
# _VISITED tracks source#tag to prevent cycles.
_VISITED=""

# Install a single dep from source, including transitive resolution.
# Args: name source target [lockfile_mode]
# lockfile_mode=1 means skip writing lockfile (caller does it)
_install_one() {
  _io_name="$1"
  _io_src="$2"
  _io_target="$3"

  _io_type="$(detect_source_type "$_io_src")"

  case "$_io_type" in
    local)
      _io_local_path="$_io_src"
      _project_root="$(_find_project_root "$PWD" 2>/dev/null)" || _project_root="$PWD"
      case "$_io_local_path" in
        ./*) _io_local_path="$_project_root/$_io_local_path" ;;
      esac
      [ -d "$_io_local_path" ] || die "local path not found: $_io_local_path"

      _io_dest="$_io_target/$_io_name"
      mkdir -p "$_io_target"
      ln -sfn "$_io_local_path" "$_io_dest"
      info "linked $_io_name -> $_io_local_path"

      # Local deps get no lockfile entry for content_sha256
      lockfile_add_entry "$_io_name" "$_io_src" "-" "-" "-"
      ;;
    github|gitlab|selfhosted)
      need_cmd curl
      need_cmd tar
      need_cmd mktemp

      _io_ver="$(source_to_version "$_io_src")"
      _io_repo_path="$(source_to_repo_path "$_io_src")"
      _io_domain="$(source_to_domain "$_io_src")"

      # Resolve version if not pinned
      if [ -z "$_io_ver" ]; then
        _resolved="$(latest_tag "$_io_type" "$_io_domain" "$_io_repo_path")"
        [ -n "$_resolved" ] || die "no tags found for $_io_repo_path"
        _io_ver="$(printf '%s' "$_resolved" | cut -f1)"
      fi

      # Check for cycle: source#tag already visited?
      _io_visit_key="${_io_type}:$_io_repo_path#${_io_ver}"
      case "$_VISITED" in
        *"|$_io_visit_key|"*)
          info "skipping already-visited $_io_visit_key (cycle or duplicate)"
          return 0
          ;;
      esac
      _VISITED="${_VISITED}|$_io_visit_key|"

      # Check if already in modules/ (conflict detection)
      _io_dest="$_io_target/$_io_name"
      if [ -d "$_io_dest" ] || [ -L "$_io_dest" ]; then
        # Check if it points to the same version
        if [ -f "$_io_dest/.version" ]; then
          _existing_ver="$(cat "$_io_dest/.version")"
          if [ "$_existing_ver" = "$_io_ver" ]; then
            info "skipping $_io_name $_io_ver (already installed)"
            # Still record in lockfile if not already there
            _io_sha=""
            _io_hash=""
            case "$_io_type" in
              github|gitlab)
                _io_sha="$(resolve_commit_sha "$_io_type" "" "$_io_repo_path" "$_io_ver")"
                ;;
              selfhosted)
                _io_sha="$(resolve_commit_sha "$_io_type" "$_io_domain" "$_io_repo_path" "$_io_ver")"
                ;;
            esac
            _io_sha="${_io_sha:-unknown}"
            lockfile_add_entry "$_io_name" "$(source_strip_version "$_io_src")" "$_io_ver" "$_io_sha" "unknown"
            return 0
          else
            warn "$_io_name: version $_io_ver requested but $_existing_ver already installed — keeping existing"
            return 0
          fi
        fi
      fi

      info "installing $_io_name ($_io_ver) from $_io_type:$_io_repo_path"

      # Install to store
      case "$_io_type" in
        github)     store_install_github "$_io_repo_path" "$_io_ver" ;;
        gitlab)     store_install_gitlab "$_io_repo_path" "$_io_ver" ;;
        selfhosted) store_install_selfhosted "$_io_domain" "$_io_repo_path" "$_io_ver" ;;
      esac

      # Symlink from modules/ to store entry
      mkdir -p "$_io_target"
      ln -sfn "$STORE_DIR/$_RES_ENTRY" "$_io_dest"

      # Write .version for compatibility with list command
      printf '%s' "$_io_ver" > "$STORE_DIR/$_RES_ENTRY/.version"

      info "installed $_io_name $_io_ver -> $_io_dest"
      lockfile_add_entry "$_io_name" "$(source_strip_version "$_io_src")" "$_RES_TAG" "$_RES_SHA" "$_RES_HASH"

      # Resolve transitive dependencies from the installed package's pike.json
      _pkg_json="$STORE_DIR/$_RES_ENTRY/pike.json"
      if [ -f "$_pkg_json" ]; then
        _trans_deps_file="$(mktemp)"
        parse_deps "$_pkg_json" > "$_trans_deps_file"
        while IFS='	' read -r _td_name _td_src; do
          info "  transitive: $_td_name from $_td_src"
          _install_one "$_td_name" "$_td_src" "$_io_target"
        done < "$_trans_deps_file"
        rm -f "$_trans_deps_file"
      fi
      ;;
  esac
}

# ── Manifest validation (warn-only) ──────────────────────────────

validate_manifests() {
  [ -d "$LOCAL_DIR" ] || return 0
  info "validating imports against declared dependencies..."

  _std_libs="Stdio Array Mapping Multiset String System Thread __builtin crypto Image Protocols Yp ADT Cache Calendar Colors Crypto Geographic GL Graphics GTK Java Locale MIME Math Media Module Parser Pike Pikefonts Process SSL Support Types Web X"

  for _moddir in "$LOCAL_DIR"/*/; do
    [ -d "$_moddir" ] || continue
    _mod_name="$(basename "$_moddir")"
    _real_dir="$(readlink -f "$_moddir" 2>/dev/null || printf '%s' "$_moddir")"

    # Collect imports from .pike and .pmod files
    _imports_file="$(mktemp)"
    find "$_real_dir" -name '*.pike' -o -name '*.pmod' 2>/dev/null | while read -r _f; do
      # Match import Foo and import "Foo" patterns
      sed -n 's/.*import[[:space:]]\+\([A-Za-z_][A-Za-z0-9_]*\).*/\1/p' "$_f" 2>/dev/null
    done | sort -u > "$_imports_file"

    # Get declared deps from this package's pike.json
    _pkg_json="$_real_dir/pike.json"
    _declared_file="$(mktemp)"
    if [ -f "$_pkg_json" ]; then
      parse_deps "$_pkg_json" | cut -f1 | sort -u > "$_declared_file"
    fi

    # Check each import against declared deps and stdlib
    while read -r _imp; do
      [ -z "$_imp" ] && continue
      # Is it the module itself?
      [ "$_imp" = "$_mod_name" ] && continue
      # Is it a Pike stdlib module?
      case " $_std_libs " in
        *" $_imp "*) continue ;;
      esac
      # Is it declared?
      if ! grep -qx "$_imp" "$_declared_file" 2>/dev/null; then
        warn "$_mod_name imports $_imp but does not declare it as a dependency"
      fi
    done < "$_imports_file"

    rm -f "$_imports_file" "$_declared_file"
  done
}

# ── Commands ───────────────────────────────────────────────────────

cmd_version() { info "pmp v$PMP_VERSION"; }

cmd_init() {
  if [ -f "$PIKE_JSON" ]; then
    die "pike.json already exists in this directory"
  fi
  cat > "$PIKE_JSON" << 'MANIFEST'
{
  "dependencies": {}
}
MANIFEST
  info "created pike.json"
}

cmd_install() {
  _global=0
  _source=""

  while [ $# -gt 0 ]; do
    case "$1" in
      -g) _global=1 ;;
      *)  _source="$1" ;;
    esac
    shift
  done

  if [ "$_global" = 1 ]; then
    _target="$GLOBAL_DIR"
  else
    _target="$LOCAL_DIR"
  fi

  if [ -z "$_source" ]; then
    [ -f "$PIKE_JSON" ] || die "no pike.json found in current directory"
    cmd_install_all "$_target"
  else
    _VISITED=""
    _LOCK_ENTRIES=""
    cmd_install_source "$_source" "$_target"
    if [ "$_global" = 0 ]; then
      write_lockfile
      # Add to pike.json
      if [ -f "$PIKE_JSON" ]; then
        _name="$(source_to_name "$_source")"
        _clean_source="$(source_strip_version "$_source")"
        add_to_manifest "$_name" "$_clean_source"
      fi
      validate_manifests
    fi
  fi
}

cmd_install_all() {
  _target="$1"
  _VISITED=""
  _LOCK_ENTRIES=""

  # Check if lockfile exists and covers all deps
  _use_lockfile=0
  if [ -f "$LOCKFILE" ] && [ "$_target" = "$LOCAL_DIR" ]; then
    _use_lockfile=1
    _lockfile_complete=1
    _deps_file="$(mktemp)"
    parse_deps "$PIKE_JSON" > "$_deps_file"
    while IFS='	' read -r _dname _dsrc; do
      if ! lockfile_has_dep "$_dname"; then
        _lockfile_complete=0
        break
      fi
    done < "$_deps_file"
    rm -f "$_deps_file"

    if [ "$_lockfile_complete" = 1 ]; then
      info "installing from $LOCKFILE (up to date)"
      _lf_deps_file="$(mktemp)"
      read_lockfile > "$_lf_deps_file"
      while IFS='	' read -r _ln _ls _lt _lsha _lhash; do
        [ -z "$_ln" ] && continue
        case "$_ls" in
          -|./**|/*)
            # Local dep — just symlink
            if [ -n "$_ls" ] && [ "$_ls" != "-" ]; then
              _local_path="$_ls"
              _project_root="$(_find_project_root "$PWD" 2>/dev/null)" || _project_root="$PWD"
              case "$_local_path" in
                ./*) _local_path="$_project_root/$_local_path" ;;
              esac
              [ -d "$_local_path" ] || { warn "local dep $_ln path $_local_path not found"; continue; }
              mkdir -p "$_target"
              ln -sfn "$_local_path" "$_target/$_ln"
              info "linked $_ln -> $_local_path"
            fi
            ;;
          *)
            # Remote dep — find or create store entry
            _entry_pattern="$(printf '%s' "$_ls" | sed 's|/|-|g')-${_lt}-*"
            _found_entry=""
            if [ -d "$STORE_DIR" ]; then
              for _se in "$STORE_DIR"/$_entry_pattern; do
                if [ -d "$_se" ]; then
                  _found_entry="$(basename "$_se")"
                  break
                fi
              done
            fi

            if [ -n "$_found_entry" ]; then
              mkdir -p "$_target"
              ln -sfn "$STORE_DIR/$_found_entry" "$_target/$_ln"
              info "installed $_ln $_lt (from lockfile)"
            else
              info "lockfile entry for $_ln not in store — re-resolving"
              _use_lockfile=0
            fi
            ;;
        esac
        lockfile_add_entry "$_ln" "$_ls" "$_lt" "$_lsha" "$_lhash"
      done < "$_lf_deps_file"
      rm -f "$_lf_deps_file"
    else
      info "lockfile is stale — re-resolving missing deps"
      _use_lockfile=0
    fi
  fi

  if [ "$_use_lockfile" = 0 ]; then
    info "installing dependencies from pike.json..."
    _deps_file="$(mktemp)"
    parse_deps "$PIKE_JSON" > "$_deps_file"
    while IFS='	' read -r _name _src; do
      _install_one "$_name" "$_src" "$_target"
    done < "$_deps_file"
    rm -f "$_deps_file"
  fi

  if [ "$_target" = "$LOCAL_DIR" ]; then
    write_lockfile
    validate_manifests
  fi

  info "done"
}

# Install from a single source specifier (top-level, no transitive/lockfile).
cmd_install_source() {
  _src="$1"
  _target="$2"
  _name="$(source_to_name "$_src")"

  _VISITED=""
  _install_one "$_name" "$_src" "$_target"
}

cmd_update() {
  _mod="$1"
  need_cmd curl

  # Remove lockfile to force fresh resolution
  rm -f "$LOCKFILE"

  if [ -n "$_mod" ]; then
    info "updating $_mod..."
    _src="$(parse_deps "$PIKE_JSON" | while IFS='	' read -r _name _s; do
      if [ "$_name" = "$_mod" ]; then printf '%s' "$_s"; break; fi
    done)"
    [ -n "$_src" ] || die "module $_mod not found in pike.json"
    _VISITED=""
    _LOCK_ENTRIES=""
    _install_one "$_mod" "$_src" "$LOCAL_DIR"
    write_lockfile
  else
    [ -f "$PIKE_JSON" ] || die "no pike.json found"
    cmd_install_all "$LOCAL_DIR"
  fi
}

cmd_lock() {
  [ -f "$PIKE_JSON" ] || die "no pike.json found"
  _VISITED=""
  _LOCK_ENTRIES=""

  info "resolving dependencies..."
  _deps_file="$(mktemp)"
  parse_deps "$PIKE_JSON" > "$_deps_file"
  while IFS='	' read -r _name _src; do
    _install_one "$_name" "$_src" "$LOCAL_DIR"
  done < "$_deps_file"
  rm -f "$_deps_file"

  write_lockfile
  info "lockfile written without installing"
}

cmd_store() {
  _subcmd="${1:-}"
  case "$_subcmd" in
    prune)
      # Remove store entries not symlinked from any project
      if [ ! -d "$STORE_DIR" ]; then
        info "no store directory"
        return 0
      fi
      _pruned=0
      for _entry in "$STORE_DIR"/*/; do
        [ -d "$_entry" ] || continue
        _ename="$(basename "$_entry")"
        # Check if any symlink in ./modules/ points to this entry
        if [ -d "$LOCAL_DIR" ]; then
          _found=0
          for _link in "$LOCAL_DIR"/*/; do
            [ -L "${_link%/}" ] || continue
            _target="$(readlink "${_link%/}" 2>/dev/null)"
            case "$_target" in
              *"$_ename"*) _found=1; break ;;
            esac
          done
          if [ "$_found" = 0 ]; then
            # Not linked from this project — but could be from others
            # Only prune if explicitly asked
            info "unused store entry: $_ename"
            _pruned=1
          fi
        fi
      done
      if [ "$_pruned" = 0 ]; then
        info "no unused entries found"
      fi
      ;;
    "")
      # Show store status
      if [ ! -d "$STORE_DIR" ]; then
        info "store is empty ($STORE_DIR)"
        return 0
      fi
      _count=0
      _size=0
      for _entry in "$STORE_DIR"/*/; do
        [ -d "$_entry" ] || continue
        _ename="$(basename "$_entry")"
        _esize="$(du -sh "$_entry" 2>/dev/null | cut -f1)"
        _tag=""
        if [ -f "$_entry/.pmp-meta" ]; then
          _tag="$(sed -n 's/^tag	//p' "$_entry/.pmp-meta")"
        fi
        printf '  %-55s %s\n' "$_ename" "$_esize"
        _count=$((_count + 1))
      done
      _total="$(du -sh "$STORE_DIR" 2>/dev/null | cut -f1)"
      printf '\n  %d entries, %s total\n' "$_count" "$_total"
      ;;
    *)
      die "unknown store subcommand: $_subcmd"
      ;;
  esac
}

cmd_list() {
  _dir="$LOCAL_DIR"
  if [ "$1" = "-g" ]; then _dir="$GLOBAL_DIR"; fi

  [ -d "$_dir" ] || { info "no modules installed"; return 0; }

  _found=0
  for _moddir in "$_dir"/*/; do
    [ -d "$_moddir" ] || continue
    _mod="$(basename "$_moddir")"
    _ver="(unknown)"
    if [ -f "$_moddir/.version" ]; then
      _ver="$(cat "$_moddir/.version")"
    fi
    _src=""
    if [ -L "${_moddir%/}" ]; then
      _link="$(readlink "${_moddir%/}")"
      case "$_link" in
        "$STORE_DIR"/*)
          _src=" (store: $(basename "$_link"))"
          ;;
        *)
          _src=" -> $_link"
          ;;
      esac
    fi
    printf '  %-20s %-12s%s\n' "$_mod" "$_ver" "$_src"
    _found=1
  done

  [ "$_found" = 0 ] && info "no modules installed"
}

cmd_clean() {
  if [ -d "$LOCAL_DIR" ]; then
    rm -rf "$LOCAL_DIR"
    info "removed $LOCAL_DIR (store preserved)"
  else
    info "nothing to clean"
  fi
}

# Build module + include paths from project root and global dir.
_build_paths() {
  _mod_paths=""
  _inc_paths=""

  _project_root="$(_find_project_root "$PWD" 2>/dev/null)" || true
  if [ -n "$_project_root" ] && [ -d "$_project_root/modules" ]; then
    _mod_paths="$_project_root/modules"
    if find "$_project_root/modules" -name '*.h' -print -quit 2>/dev/null | grep -q .; then
      _inc_paths="$_project_root/modules"
    fi
  fi

  _pjson="${_project_root:-$PWD}/pike.json"
  if [ -f "$_pjson" ]; then
    _local_deps_file="$(mktemp)"
    parse_deps "$_pjson" > "$_local_deps_file"
    while IFS='	' read -r _name _src; do
      case "$_src" in
        ./*|/*)
          _local_path="$_src"
          case "$_local_path" in
            ./*) _local_path="${_project_root:-$PWD}/$_local_path" ;;
          esac
          [ -d "$_local_path" ] || continue
          _mod_paths="${_mod_paths:+$_mod_paths:}$_local_path"
          if find "$_local_path" -name '*.h' -print -quit 2>/dev/null | grep -q .; then
            _inc_paths="${_inc_paths:+$_inc_paths:}$_local_path"
          fi
          ;;
      esac
    done < "$_local_deps_file"
    rm -f "$_local_deps_file"
  fi

  if [ -d "$GLOBAL_DIR" ]; then
    _mod_paths="${_mod_paths:+$_mod_paths:}$GLOBAL_DIR"
    if find "$GLOBAL_DIR" -name '*.h' -print -quit 2>/dev/null | grep -q .; then
      _inc_paths="${_inc_paths:+$_inc_paths:}$GLOBAL_DIR"
    fi
  fi
}

cmd_run() {
  [ -n "$1" ] || die "usage: pmp run <script.pike> [args...]"

  _script="$1"
  shift

  _build_paths

  _env=""
  if [ -n "$_mod_paths" ]; then
    _env="PIKE_MODULE_PATH=$_mod_paths${PIKE_MODULE_PATH+:$PIKE_MODULE_PATH}"
  fi
  if [ -n "$_inc_paths" ]; then
    _env="${_env:+$_env }PIKE_INCLUDE_PATH=$_inc_paths${PIKE_INCLUDE_PATH+:$PIKE_INCLUDE_PATH}"
  fi

  if [ -n "$_env" ]; then
    env $_env "$PIKE_BIN" "$_script" "$@"
  else
    exec "$PIKE_BIN" "$_script" "$@"
  fi
}

# ── Environment ────────────────────────────────────────────────────

cmd_env() {
  _env_dir=".pike-env"
  _env_bin="$_env_dir/bin"

  if [ -d "$_env_dir" ]; then
    info ".pike-env/ already exists — recreating bin/pike wrapper"
  fi

  mkdir -p "$_env_bin"

  _project_root="$(_find_project_root "$PWD" 2>/dev/null)" || _project_root="$PWD"

  cat > "$_env_bin/pike" << PIKE_WRAPPER
#!/bin/sh
# Generated by pmp env. Re-run 'pmp env' to update.
PROJECT_ROOT="$_project_root"
PIKE_BIN="$PIKE_BIN"
GLOBAL_DIR="\$HOME/.pike/modules"

MOD_PATHS=""
INC_PATHS=""

# Project modules
if [ -d "\$PROJECT_ROOT/modules" ]; then
  MOD_PATHS="\$PROJECT_ROOT/modules"
  if find "\$PROJECT_ROOT/modules" -name '*.h' -print -quit 2>/dev/null | grep -q .; then
    INC_PATHS="\$PROJECT_ROOT/modules"
  fi
fi

# Local dependencies from pike.json (paths starting with ./ or /)
_PIKE_JSON="\$PROJECT_ROOT/pike.json"
if [ -f "\$_PIKE_JSON" ]; then
  _in_deps=0
  while IFS= read -r _line; do
    case "\$_line" in
      *dependencies* ) _in_deps=1; continue ;;
    esac
    if [ "\$_in_deps" = 1 ]; then
      case "\$_line" in
        *'}'* ) _in_deps=0; continue ;;
      esac
      _val="\$(printf '%s' "\$_line" | sed -n 's/.*"[^"]*"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')"
      if [ -n "\$_val" ]; then
        case "\$_val" in
          ./*|/*)
            _lpath="\$_val"
            case "\$_lpath" in
              ./*) _lpath="\$PROJECT_ROOT/\$_lpath" ;;
            esac
            [ -d "\$_lpath" ] || continue
            MOD_PATHS="\${MOD_PATHS:+\$MOD_PATHS:}\$_lpath"
            if find "\$_lpath" -name '*.h' -print -quit 2>/dev/null | grep -q .; then
              INC_PATHS="\${INC_PATHS:+\$INC_PATHS:}\$_lpath"
            fi
            ;;
        esac
      fi
    fi
  done < "\$_PIKE_JSON"
fi

# Global modules
if [ -d "\$GLOBAL_DIR" ]; then
  MOD_PATHS="\${MOD_PATHS:+\$MOD_PATHS:}\$GLOBAL_DIR"
fi

# Build environment and exec real Pike
_env=""
if [ -n "\$MOD_PATHS" ]; then
  _env="PIKE_MODULE_PATH=\$MOD_PATHS\${PIKE_MODULE_PATH+:\$PIKE_MODULE_PATH}"
fi
if [ -n "\$INC_PATHS" ]; then
  _env="\${_env:+\$_env }PIKE_INCLUDE_PATH=\$INC_PATHS\${PIKE_INCLUDE_PATH+:\$PIKE_INCLUDE_PATH}"
fi

if [ -n "\$_env" ]; then
  exec env \$_env "\$PIKE_BIN" "\$@"
else
  exec "\$PIKE_BIN" "\$@"
fi
PIKE_WRAPPER

  chmod +x "$_env_bin/pike"

  _abs_env_dir="$(cd "$_env_dir" && pwd)"
  cat > "$_env_dir/activate" << 'ACTIVATE'
# pmp environment activation. Source this: . .pike-env/activate

# Env directory is baked in at creation time
_pike_env_dir="ACTIVATE_PLACEHOLDER"
_pike_env_bin="$_pike_env_dir/bin"

# Save original PATH
if [ -z "$_pike_env_old_path" ]; then
  _pike_env_old_path="$PATH"
fi

# Prepend env bin to PATH
PATH="$_pike_env_bin:$PATH"
export PATH

# Marker for detection
PIKE_ENV_PATH="$_pike_env_dir"
export PIKE_ENV_PATH

pmp_deactivate() {
  if [ -n "$_pike_env_old_path" ]; then
    PATH="$_pike_env_old_path"
    export PATH
    unset _pike_env_old_path
  fi
  unset PIKE_ENV_PATH
  if [ -n "$_pike_env_old_ps1" ]; then
    PS1="$_pike_env_old_ps1"
    unset _pike_env_old_ps1
  fi
  unset -f pmp_deactivate
}

# Shell prompt indicator
if [ -z "$_pike_env_old_ps1" ]; then
  _pike_env_old_ps1="$PS1"
  PS1="(pike) $PS1"
fi
ACTIVATE
  sed -i "s|ACTIVATE_PLACEHOLDER|$_abs_env_dir|" "$_env_dir/activate"

  info "created .pike-env/"
  info "  activate with:  . .pike-env/activate"
  info "  or use directly: .pike-env/bin/pike"
}

# ── Main ───────────────────────────────────────────────────────────

_cmd="${1:-}"
shift 2>/dev/null || true

case "$_cmd" in
  init)     cmd_init "$@" ;;
  install)  cmd_install "$@" ;;
  update)   cmd_update "$@" ;;
  lock)     cmd_lock "$@" ;;
  store)    cmd_store "$@" ;;
  list)     cmd_list "$@" ;;
  clean)    cmd_clean ;;
  run)      cmd_run "$@" ;;
  env)      cmd_env ;;
  version)  cmd_version ;;
  -h|--help)
    printf 'pmp — Pike Module Package Manager\n\n'
    printf 'Usage:\n'
    printf '  pmp init                                    Create pike.json\n'
    printf '  pmp install                                 Install all deps (from lockfile or pike.json)\n'
    printf '  pmp install <url>                           Add and install dependency\n'
    printf '  pmp install <url>#tag                       Install specific version\n'
    printf '  pmp install ./local/path                    Local dependency (symlinked)\n'
    printf '  pmp install -g <url>                        Install system-wide\n'
    printf '  pmp update [module]                         Update deps to latest tags\n'
    printf '  pmp lock                                    Write pike.lock without installing\n'
    printf '  pmp store                                   Show store entries and disk usage\n'
    printf '  pmp store prune                             Show unused store entries\n'
    printf '  pmp list [-g]                               Show installed dependencies\n'
    printf '  pmp env                                     Create .pike-env/ virtual environment\n'
    printf '  pmp clean                                   Remove ./modules/ (keeps store)\n'
    printf '  pmp run <script>                            Run script with module paths\n'
    printf '  pmp version                                 Show version\n'
    printf '\nSource formats:\n'
    printf '  github.com/owner/repo                       GitHub\n'
    printf '  gitlab.com/owner/repo                       GitLab\n'
    printf '  git.example.com/owner/repo                  Self-hosted git\n'
    printf '  ./local/path or /abs/path                   Local module\n'
    ;;
  *)
    die "unknown command '$_cmd' (try: pmp --help)"
    ;;
esac
