# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Source code
*.c text eol=lf
*.h text eol=lf
*.pike text eol=lf
*.pmod text eol=lf
*.go text eol=lf
*.py text eol=lf
*.rs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.sh text eol=lf
*.bash text eol=lf

# Config and data
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.csv text eol=lf

# Web
*.css text eol=lf
*.html text eol=lf

# Binary files (explicitly mark to prevent conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
